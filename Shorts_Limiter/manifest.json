{
  "manifest_version": 3,
  "name": "YouTube Shorts Limiter",
  "version": "1.1",
  "description": "Redirects you to the YouTube homepage after watching a set number or Shorts.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}